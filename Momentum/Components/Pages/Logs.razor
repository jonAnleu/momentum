@page "/logs"
@rendermode InteractiveServer


<MudTabs>
    <MudTabPanel Text="Runs">
        @if (isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else if (errorMessage != null)
        {
            <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
        }
        else
        {
            <MudTable Items="runs" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Distance (mi)</MudTh>
                    <MudTh>Duration</MudTh>
                    <MudTh>Avg HR</MudTh>
                    <MudTh>Pace</MudTh>
                    <MudTh>Notes</MudTh>
                </HeaderContent>
                <RowTemplate Context="run">
                    <MudTd>@run.Date?.ToString("MM/dd/yyyy")</MudTd>
                    <MudTd>@run.Distance?.ToString("F2")</MudTd>
                    <MudTd>@FormatTimeSpan(run.Duration)</MudTd>
                    <MudTd>@run.AvgHr</MudTd>
                    <MudTd>@FormatTimeSpan(run.Pace)</MudTd>
                    <MudTd>@run.Notes</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
</MudTabs>

@code {
    private List<Run> runs = new List<Run>();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
      
    }

    private string FormatTimeSpan(TimeSpan? timeSpan)
    {
        return timeSpan.HasValue ? timeSpan.Value.ToString(@"hh\:mm\:ss") : "N/A";
    }
}
