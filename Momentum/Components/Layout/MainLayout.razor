@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme"  />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Warning" Elevation="2">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />
         MOMENTUM
        <MudSpacer />
        <MudSwitch @bind-Value="_isDarkMode" Color="Color.Dark" Class="ma-4" T="bool" Label="Light/Dark"/>
    </MudAppBar>
    <MudDrawer @bind-Open="@_drawerOpen" Class="sidebar">
        <NavMenu />
    </MudDrawer>
    <MudContainer MaxWidth="MaxWidth.Medium" Class="main-content">
        @Body
    </MudContainer>
</MudLayout>

@code {
     private MudTheme _theme = new();
    private bool _isDarkMode;
    bool _drawerOpen = true;

    void DrawerToggle() {
        _drawerOpen = !_drawerOpen;
    }
}